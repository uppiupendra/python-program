def fibonacci(n):
    #check if n is 1 or 2 (base case for fibonacci)
    if n == 1 or n ==2:
        # if n is 1 or 2, return 1 (fibonacci sequence starts with 1,1)
        return 1 
    else:
        # if n is greater than 2, recursively call that fibonacci function
        # to calculate the sum of the (n-1)th and (n-2)th fibonacci number
        return fibonacci(n-1) + fibonacci(n-2)

#print the result of calling the fibonacci function with the input value
print(fibonacci(7))
    
    
    
